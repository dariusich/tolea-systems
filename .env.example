TRADEJOURNAL_DB_PATH=./db/trades.sqlite
TRADEJOURNAL_HOST=127.0.0.1
TRADEJOURNAL_PORT=8000
TRADEJOURNAL_COLLECTOR_KEY=replace-with-a-long-secret
TRADEJOURNAL_ADMIN_KEY=replace-with-an-admin-secret
TRADEJOURNAL_PUBLIC_TOKEN=

# Collector mode. Leave TRADEJOURNAL_SERVER_URL empty for local desktop/offline ingest.
TRADEJOURNAL_SERVER_URL=https://your-dashboard-api.example.com
TRADEJOURNAL_POLL_INTERVAL=10
TRADEJOURNAL_ENABLE_MT5=1
TRADEJOURNAL_ENABLE_MT4=1
TRADEJOURNAL_MT5_PATHS=
TRADEJOURNAL_MT4_SPOOL=

